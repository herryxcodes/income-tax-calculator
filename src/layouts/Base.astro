---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const siteUrl = "https://calctax.ca";
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="en-CA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow, max-image-preview:large" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Outfit:wght@300..700&display=swap" rel="stylesheet" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="CalcTax" />
    <meta property="og:image" content="https://calctax.ca/logo.png" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://calctax.ca/logo.png" />

    <!-- hreflang -->
    <link rel="alternate" hreflang="en-CA" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Organization Schema (site-wide) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "CalcTax",
      "url": "https://calctax.ca",
      "description": "Free, privacy-first Canadian income tax calculators.",
      "logo": "https://calctax.ca/logo.png",
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "hello@calctax.ca",
        "contactType": "customer service",
        "availableLanguage": "English"
      }
    })} />
  </head>
  <body class="bg-[#FAFAF8] text-slate-800 antialiased">
    <!-- Header -->
    <header class="sticky top-0 z-50 bg-slate-900/[0.97] backdrop-blur-xl border-b border-white/[0.06]">
      <nav class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 hover:opacity-90 transition-opacity">
          <img src="/logo.png" alt="CalcTax" class="h-8 w-8" />
          <span class="text-xl font-bold text-teal-400 tracking-tight font-display">CalcTax</span>
        </a>

        <!-- Mobile menu button -->
        <button
          type="button"
          id="menu-toggle"
          class="md:hidden text-slate-400 hover:text-white transition-colors"
          aria-label="Toggle menu"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>

        <!-- Desktop nav -->
        <div class="hidden md:flex items-center gap-7 text-sm">
          <a href="/income-tax-calculator" class="text-slate-400 hover:text-white transition-colors nav-link">Tax Calculator</a>
          <a href="/rrsp-calculator" class="text-slate-400 hover:text-white transition-colors nav-link">RRSP</a>
          <a href="/self-employed-tax-calculator" class="text-slate-400 hover:text-white transition-colors nav-link">Self-Employed</a>
          <a href="/blog" class="text-slate-400 hover:text-white transition-colors nav-link">Blog</a>
        </div>
      </nav>

      <!-- Mobile nav -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-white/[0.06]">
        <div class="max-w-6xl mx-auto px-4 py-3 flex flex-col gap-2 text-sm">
          <a href="/income-tax-calculator" class="text-slate-400 hover:text-white transition-colors py-1.5">Tax Calculator</a>
          <a href="/rrsp-calculator" class="text-slate-400 hover:text-white transition-colors py-1.5">RRSP</a>
          <a href="/self-employed-tax-calculator" class="text-slate-400 hover:text-white transition-colors py-1.5">Self-Employed</a>
          <a href="/blog" class="text-slate-400 hover:text-white transition-colors py-1.5">Blog</a>
        </div>
      </div>
    </header>

    <main class="animate-fade-in">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-slate-900 text-slate-400 mt-20">
      <div class="max-w-6xl mx-auto px-4 py-12">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-sm">
          <div class="col-span-2 md:col-span-1">
            <a href="/" class="flex items-center gap-2">
              <img src="/logo.png" alt="CalcTax" class="h-7 w-7" />
              <span class="text-lg font-bold text-teal-400 font-display">CalcTax</span>
            </a>
            <p class="mt-3 text-slate-500 text-xs leading-relaxed max-w-[220px]">
              Free, privacy-first tax calculators for Canadians. Your data never leaves your browser.
            </p>
          </div>
          <div>
            <h3 class="font-semibold text-slate-300 mb-4 text-xs uppercase tracking-wider">Calculators</h3>
            <ul class="space-y-2.5">
              <li><a href="/income-tax-calculator" class="hover:text-slate-200 transition-colors">Income Tax</a></li>
              <li><a href="/rrsp-calculator" class="hover:text-slate-200 transition-colors">RRSP Savings</a></li>
              <li><a href="/self-employed-tax-calculator" class="hover:text-slate-200 transition-colors">Self-Employed</a></li>
            </ul>
          </div>
          <div>
            <h3 class="font-semibold text-slate-300 mb-4 text-xs uppercase tracking-wider">By Province</h3>
            <ul class="space-y-2.5">
              <li><a href="/ontario-income-tax-calculator" class="hover:text-slate-200 transition-colors">Ontario</a></li>
              <li><a href="/quebec-income-tax-calculator" class="hover:text-slate-200 transition-colors">Quebec</a></li>
              <li><a href="/bc-income-tax-calculator" class="hover:text-slate-200 transition-colors">BC</a></li>
              <li><a href="/alberta-income-tax-calculator" class="hover:text-slate-200 transition-colors">Alberta</a></li>
              <li><a href="/manitoba-income-tax-calculator" class="hover:text-slate-200 transition-colors">Manitoba</a></li>
              <li><a href="/saskatchewan-income-tax-calculator" class="hover:text-slate-200 transition-colors">Saskatchewan</a></li>
            </ul>
          </div>
          <div>
            <h3 class="font-semibold text-slate-300 mb-4 text-xs uppercase tracking-wider">Legal</h3>
            <ul class="space-y-2.5">
              <li><a href="/about" class="hover:text-slate-200 transition-colors">About</a></li>
              <li><a href="/privacy" class="hover:text-slate-200 transition-colors">Privacy</a></li>
              <li><a href="/terms" class="hover:text-slate-200 transition-colors">Terms</a></li>
              <li><a href="/disclaimer" class="hover:text-slate-200 transition-colors">Disclaimer</a></li>
              <li><a href="/disclosure" class="hover:text-slate-200 transition-colors">Disclosure</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-10 pt-6 border-t border-slate-800 text-xs text-slate-600 flex flex-col md:flex-row justify-between gap-2">
          <p>&copy; {new Date().getFullYear()} CalcTax. Estimates only — not financial advice. <a href="/disclaimer" class="underline hover:text-slate-400 transition-colors">Disclaimer</a>.</p>
          <p>2025 CRA rates. Your data never leaves your browser.</p>
        </div>
      </div>
    </footer>

    <script>
      document.getElementById('menu-toggle')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
