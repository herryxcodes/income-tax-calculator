---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

// Get published blog posts from content collection
const publishedPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const tagColors: Record<string, string> = {
  red: "bg-rose-50 text-rose-700 ring-1 ring-inset ring-rose-200/60",
  green: "bg-emerald-50 text-emerald-700 ring-1 ring-inset ring-emerald-200/60",
  orange: "bg-amber-50 text-amber-700 ring-1 ring-inset ring-amber-200/60",
  blue: "bg-teal-50 text-teal-700 ring-1 ring-inset ring-teal-200/60",
  gray: "bg-slate-50 text-slate-600 ring-1 ring-inset ring-slate-200/60",
};
---

<Base
  title="Canadian Tax Guides 2025 — Filing Tips, Calculators & More | CalcTax"
  description="Practical tax guides for the 2025 tax year. Tax brackets, RRSP strategies, self-employment, gig worker rules, and province-specific guides."
>
  <div class="max-w-3xl mx-auto px-4 py-16">
    <div class="mb-10">
      <h1 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4 font-display tracking-tight animate-fade-up">Canadian Tax Guides</h1>
      <p class="text-lg text-slate-500 leading-relaxed animate-fade-up" style="animation-delay: 0.1s">
        Practical tax guides for Canadians filing their 2025 return. Plain language, no jargon, with calculators to see your exact numbers.
      </p>
    </div>

    <!-- Filing season banner -->
    <div class="bg-rose-50 border border-rose-200 rounded-xl p-4 mb-10 animate-fade-up" style="animation-delay: 0.15s">
      <p class="text-sm text-rose-800">
        <strong>Tax season is open.</strong> The deadline to file your 2025 return is
        <strong>April 30, 2026</strong> (self-employed: June 15, 2026).
        <a href="/income-tax-calculator" class="underline font-semibold hover:text-rose-900">Estimate your tax now</a>
      </p>
    </div>

    <div class="space-y-6">
      {publishedPosts.map((post) => (
        <article class="border-b border-slate-100 pb-6 group">
          <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${tagColors[post.data.tagColor] || tagColors.gray}`}>
            {post.data.tag}
          </span>
          <h2 class="text-lg font-semibold text-slate-900 mt-2.5">
            <a href={`/blog/${post.id}`} class="group-hover:text-teal-600 transition-colors">
              {post.data.title}
            </a>
          </h2>
          <p class="text-sm text-slate-500 mt-1.5 leading-relaxed">
            {post.data.description}
          </p>
        </article>
      ))}
    </div>
  </div>
</Base>
